    background-color: #fff3e0;
    margin: 0;
    padding: 0;
    color: #5d3a00;
  }
  h1, h2, h3 {
    color: #c56c09;
  }
  a {
    color: #c56c09;
    text-decoration: none;
  }
  a:hover {
    text-decoration: underline;
  }

  header {
    background: #ffa726;
    color: white;
    padding: 15px 10px;
    text-align: center;
    font-weight: bold;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .container {
    padding: 15px;
    max-width: 900px;
    margin: auto;
  }

  /* Contact & WhatsApp Button */
