    color: white;
    font-weight: 700;
    border: none;
    padding: 12px 20px;
    width: 100%;
    max-width: 400px;
    margin: 10px auto;
    display: block;
    border-radius: 25px;
    font-size: 1.1rem;
    cursor: pointer;
    transition: 0.3s;
  }
  .whatsapp-btn:hover {
    background: #1ebe57;
  }

  /* Menu Section */
  section.menu-section {
    margin-bottom: 30px;
  }
  ul.menu-list {
    list-style: none;
    padding-left: 0;
  }
  ul.menu-list li {
    border-bottom: 1px dotted #c56c09;
    padding: 8px 0;
    display: flex;
    justify-content: space-between;
  }

  /* Thali Section Design */
  .thali-box {
    border: 2px solid #c56c09;
    border-radius: 10px;
    margin-bottom: 15px;
    padding: 15px;
    background: #ffecb3;
  }
  .thali-box h3 {
    margin-top: 0;
    margin-bottom: 10px;
    color: #a05200;
